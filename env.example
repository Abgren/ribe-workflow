# ── Microsoft 365 ──────────────────────────────────────────────
AZURE_CLIENT_ID=71fa604b-a57c-407b-882e-981f21da34dc
AZURE_TENANT_ID=c8afe53a-cd76-4e7b-a0bb-6bd02b80b4f6

# ── Session (byt ut mot en lång slumpmässig sträng) ────────────
SESSION_SECRET=byt-ut-detta-till-nagot-langt-och-slumpmassigt

# ── Fortnox ────────────────────────────────────────────────────
# Hämtas från Fortnox: Inställningar → Integrationer → API-nycklar
FORTNOX_ACCESS_TOKEN=
FORTNOX_CLIENT_SECRET=

# ── App ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# URL dit appen är publicerad (används för Microsoft redirect)
APP_URL=https://din-app.up.railway.app

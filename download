    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        // ============================================================================
        // MSAL CONFIGURATION & STATE
        // ============================================================================
        
        let msalInstance = null;
        let accessToken = null;
        let currentUser = null;
        let currentTab = 'ar';
        let currentEditingJobId = null;
        let currentEditingType = null;
        let currentEditingBestId = null;
        let currentBestFilter = 'all';
        let arCalendar = null;
        let somCalendar = null;
        let msSalesNames = ['Danne', 'Tessan', 'Tina', 'Anders'];
        let msMontörNames = ['Ali', 'Hampus', 'Mukta', 'David'];
        let msSewersNames = [];
        
        // ============================================================================
        // UTILITY FUNCTIONS
        // ============================================================================
        
        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `<strong>${type === 'success' ? 'OK!' : 'Fel!'}</strong> ${message}`;
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }
        
        function formatDate(date) {
            if (!date) return '';
            const d = new Date(date);
            return d.toISOString().split('T')[0];
        }
        
        function generateOrderNumber(type) {
            const year = new Date().getFullYear();
            const timestamp = Date.now().toString(36);
            const prefix = type === 'ar' ? 'AO' : 'SO';
            return `${prefix}-${year}-${timestamp}`;
        }
        
        function generateBestOrdernr() {
            const year = new Date().getFullYear();
            const timestamp = Date.now().toString(36);
            return `BEST-${year}-${timestamp}`;
        }
        
        // ============================================================================
        // API FUNCTIONS
        // ============================================================================
        
        async function apiCall(method, endpoint, body = null) {
            try {
                const options = {
                    method,
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${accessToken}`
                    }
                };
                
                if (body) {
                    options.body = JSON.stringify(body);
                }
                
                const response = await fetch(`/api${endpoint}`, options);
                
                if (!response.ok) {
                    if (response.status === 401) {
                        handleLogout();
                        return null;
                    }
                    throw new Error(`API Error: ${response.status}`);
                }
                
                return await response.json();
            } catch (error) {
                console.error('API Call Error:', error);
                showToast(`Fel: ${error.message}`, 'error');
                return null;
            }
        }
        
        async function loadOrders(type) {
            const endpoint = `/orders/${type}`;
            return await apiCall('GET', endpoint) || [];
        }
        
        async function saveOrder(type, order) {
            const isNew = !order.id;
            const endpoint = isNew ? `/orders/${type}` : `/orders/${type}/${order.id}`;
            const method = isNew ? 'POST' : 'PUT';
            return await apiCall(method, endpoint, order);
        }
        
        async function deleteOrder(type, id) {
            const endpoint = `/orders/${type}/${id}`;
            return await apiCall('DELETE', endpoint);
        }
        
        async function syncFortnox() {
            try {
                const response = await apiCall('POST', '/fortnox/sync');
                if (response) {
                    showToast('Fortnox synkronisering påbörjad');
                    return true;
                }
            } catch (error) {
                console.error('Fortnox sync error:', error);
            }
            return false;
        }
        
        // ============================================================================
        // MSAL INITIALIZATION
        // ============================================================================
        
        async function initMsal() {
            try {
                // Fetch config from backend
                const configResponse = await fetch('/api/config');
                const config = await configResponse.json();
                
                const msalConfig = {
                    auth: {
                        clientId: config.clientId,
                        authority: `https://login.microsoftonline.com/${config.tenantId}`,
                        redirectUri: window.location.origin + '/'
                    },
                    cache: {
                        cacheLocation: 'localStorage',
                        storeAuthStateInCookie: false
                    }
                };
                
                msalInstance = new msal.PublicClientApplication(msalConfig);
                await msalInstance.initialize();
                
                // Check if user is already logged in
                const accounts = msalInstance.getAllAccounts();
                if (accounts.length > 0) {
                    currentUser = accounts[0];
                    await acquireToken();
                    showMainApp();
                    await initializeApp();
                } else {
                    showLoginScreen();
                }
            } catch (error) {
                console.error('MSAL initialization error:', error);
                showToast('Initialisering av login misslyckades', 'error');
            }
        }
        
        async function acquireToken() {
            try {
                const request = {
                    scopes: ['https://graph.microsoft.com/.default'],
                    account: currentUser
                };
                
                const response = await msalInstance.acquireTokenSilent(request);
                accessToken = response.accessToken;
                return accessToken;
            } catch (error) {
                console.error('Token acquisition error:', error);
                showToast('Kunde inte hämta åtkomsttoken', 'error');
                return null;
            }
        }
        
        async function handleLogin() {
            try {
                const response = await msalInstance.loginPopup({
                    scopes: ['https://graph.microsoft.com/.default']
                });
                
                currentUser = response.account;
                msalInstance.setActiveAccount(currentUser);
                accessToken = response.accessToken;
                
                showMainApp();
                await initializeApp();
            } catch (error) {
                console.error('Login error:', error);
                document.getElementById('loginError').textContent = 'Inloggning misslyckades. Försök igen.';
                document.getElementById('loginError').style.display = 'block';
            }
        }
        
        function handleLogout() {
            msalInstance.logout();
        }
        
        function showLoginScreen() {
            document.getElementById('loginScreen').style.display = 'flex';
            document.getElementById('mainApp').style.display = 'none';
        }
        
        function showMainApp() {
            document.getElementById('loginScreen').style.display = 'none';
            document.getElementById('mainApp').style.display = 'block';
        }
        
        // ============================================================================
        // APPLICATION INITIALIZATION
        // ============================================================================
        
        async function initializeApp() {
            // Load settings
            const settingsResp = await apiCall('GET', '/settings');
            if (settingsResp) {
                document.getElementById('settingsTenantId').value = settingsResp.tenantId || '';
                document.getElementById('settingsClientId').value = settingsResp.clientId || '';
                document.getElementById('settingsRedirectUri').value = settingsResp.redirectUri || '';
                document.getElementById('settingsCompanyName').value = settingsResp.companyName || '';
            }
            
            // Load initial data for AR tab
            await loadAndRenderArJobs();
            
            // Setup event listeners
            setupEventListeners();
        }
        
        // ============================================================================
        // TAB NAVIGATION
        // ============================================================================
        
        async function switchTab(tab) {
            currentTab = tab;
            
            // Update navbar tabs
            document.querySelectorAll('.nav-link').forEach(el => {
                el.classList.remove('active');
                if (el.dataset.tab === tab) {
                    el.classList.add('active');
                }
            });
            
            // Update tab panels
            document.querySelectorAll('.tab-panel').forEach(el => {
                el.classList.remove('active');
            });
            document.querySelector('.tab-panel-' + tab).classList.add('active');
            
            // Load and render appropriate data
            if (tab === 'ar') {
                if (!arCalendar) initArCalendar();
                await loadAndRenderArJobs();
                setTimeout(() => arCalendar && arCalendar.updateSize(), 150);
            } else if (tab === 'som') {
                if (!somCalendar) initSomCalendar();
                await loadAndRenderSomJobs();
                setTimeout(() => somCalendar && somCalendar.updateSize(), 150);
            } else if (tab === 'best') {
                await renderBestTable();
            }
        }
        
        // ============================================================================
        // ARBETSORDER (AR) FUNCTIONS
        // ============================================================================
        
        async function loadAndRenderArJobs() {
            const jobs = await loadOrders('ar');
            renderArList(jobs);
            updateArCalendar(jobs);
        }
        
        function renderArList(jobs) {
            const container = document.getElementById('kommande-ar');
            const searchText = document.getElementById('searchArInput').value.toLowerCase();
            const statusFilter = document.querySelector('#filterArStatus .status-btn.active')?.dataset.status || 'all';
            
            let filtered = jobs;
            
            if (statusFilter !== 'all') {
                filtered = filtered.filter(j => j.status === statusFilter);
            }
            
            if (searchText) {
                filtered = filtered.filter(j => 
                    (j.ordernr || '').toLowerCase().includes(searchText) ||
                    (j.projekt || '').toLowerCase().includes(searchText)
                );
            }
            
            container.innerHTML = filtered.map(job => `
                <div class="kommande-item" onclick="editArJob('${job.id}')">
                    <div class="kommande-item-nr">${job.ordernr}</div>
                    <div class="kommande-item-info">${job.projekt}</div>
                    <div class="kommande-item-info">
                        <span class="status-pill ${job.status}">${job.status}</span>
                    </div>
                </div>
            `).join('');
        }
        
        function updateArCalendar(jobs) {
            if (!arCalendar) return;
            
            const events = jobs
                .filter(job => job.status !== 'utkast' && job.status !== 'ny' && job.datum)
                .map(job => ({
                    id: job.id,
                    title: `${job.ordernr} - ${job.kund}`,
                    start: job.datum,
                    backgroundColor: getStatusColor(job.status, 'ar'),
                    borderColor: getStatusColor(job.status, 'ar'),
                    textColor: job.status === 'preliminar' ? '#333' : '#fff'
                }));
            
            arCalendar.removeAllEvents();
            arCalendar.addEventSource(events);
        }
        
        function getStatusColor(status, type = 'ar') {
            const colors = {
                ar: {
                    'utkast': '#9E9E9E',
                    'ny': '#7B1FA2',
                    'preliminar': '#7EC8E3',
                    'bokad': '#1565C0',
                    'atergång': '#E65100',
                    'klar': '#2E7D32'
                },
                som: {
                    'utkast': '#9E9E9E',
                    'ny': '#00695C',
                    'sy': '#00897B',
                    'klar': '#2E7D32'
                }
            };
            return colors[type]?.[status] || '#999';
        }
        
        async function editArJob(jobId) {
            const jobs = await loadOrders('ar');
            const job = jobs.find(j => j.id === jobId);
            if (!job) return;
            
            currentEditingJobId = jobId;
            currentEditingType = 'ar';
            
            showArJobModal(job);
        }
        
        function showArJobModal(job = null) {
            const isNew = !job;
            const jobData = job || {
                ordernr: generateOrderNumber('ar'),
                status: 'utkast',
                datum: formatDate(new Date())
            };
            
            document.getElementById('jobModalTitle').textContent = isNew ? 'Ny Arbetsorder' : `Arbetsorder ${jobData.ordernr}`;
            
            // Build form HTML
            let formHtml = `
                <div class="form-section">
                    <label class="form-label">Ordernr</label>
                    <input type="text" class="form-control ar-field" id="ar_ordernr" value="${jobData.ordernr || ''}" readonly style="background: #f0f0f0;">
                </div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-section">
                        <label class="form-label">Datum</label>
                        <input type="date" class="form-control ar-field" id="ar_datum" value="${jobData.datum || ''}">
                    </div>
                    <div class="form-section">
                        <label class="form-label">Kund</label>
                        <input type="text" class="form-control ar-field" id="ar_kund" value="${jobData.kund || ''}" placeholder="Kundnamn">
                    </div>
                </div>
                
                <div class="form-section">
                    <label class="form-label">Projekt</label>
                    <input type="text" class="form-control ar-field" id="ar_projekt" value="${jobData.projekt || ''}" placeholder="Projektnamn">
                </div>
                
                <div class="form-section">
                    <h6 class="form-section-title">Status</h6>
                    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                        <button type="button" class="status-pill ${jobData.status === 'utkast' ? 'active' : ''}" data-ar-status="utkast" style="background: ${jobData.status === 'utkast' ? 'var(--status-utkast)' : '#eee'}; color: ${jobData.status === 'utkast' ? 'white' : '#333'};">Utkast</button>
                        <button type="button" class="status-pill ${jobData.status === 'ny' ? 'active' : ''}" data-ar-status="ny" style="background: ${jobData.status === 'ny' ? 'var(--status-ny-ar)' : '#eee'}; color: white;">NY</button>
                        <button type="button" class="status-pill ${jobData.status === 'preliminar' ? 'active' : ''}" data-ar-status="preliminar" style="background: ${jobData.status === 'preliminar' ? 'var(--status-preliminar)' : '#eee'}; color: ${jobData.status === 'preliminar' ? '#333' : '#333'};">Prel.</button>
                        <button type="button" class="status-pill ${jobData.status === 'bokad' ? 'active' : ''}" data-ar-status="bokad" style="background: ${jobData.status === 'bokad' ? 'var(--status-bokad)' : '#eee'}; color: white;">Bokad</button>
                        <button type="button" class="status-pill ${jobData.status === 'atergång' ? 'active' : ''}" data-ar-status="atergång" style="background: ${jobData.status === 'atergång' ? 'var(--status-atergång)' : '#eee'}; color: white;">Återgång</button>
                        <button type="button" class="status-pill ${jobData.status === 'klar' ? 'active' : ''}" data-ar-status="klar" style="background: ${jobData.status === 'klar' ? 'var(--status-klar)' : '#eee'}; color: white;">Klar</button>
                    </div>
                </div>
                
                <div class="form-section">
                    <label class="form-label">Anteckningar</label>
                    <textarea class="form-control ar-field" id="ar_anteckningar" rows="3" placeholder="Noteringar...">${jobData.anteckningar || ''}</textarea>
                </div>
            `;
            
            document.getElementById('jobModalBody').innerHTML = formHtml;
            
            // Setup status pill listeners
            document.querySelectorAll('[data-ar-status]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('[data-ar-status]').forEach(b => {
                        b.style.background = '#eee';
                        b.style.color = '#333';
                        b.classList.remove('active');
                    });
                    const status = e.target.dataset.arStatus;
                    e.target.style.background = getStatusColor(status, 'ar');
                    e.target.style.color = ['preliminar', 'utkast'].includes(status) ? '#333' : 'white';
                    e.target.classList.add('active');
                });
            });
            
            document.getElementById('saveJobBtn').onclick = () => saveArJob(jobData);
            
            bootstrap.Modal.getOrCreateInstance(document.getElementById('jobModal')).show();
        }
        
        async function saveArJob(originalJobData) {
            const activeStatusBtn = document.querySelector('[data-ar-status].active');
            const status = activeStatusBtn?.dataset.arStatus || 'utkast';
            
            const jobData = {
                id: currentEditingJobId || ('ar_' + Date.now().toString(36) + Math.random().toString(36).slice(2)),
                ordernr: document.getElementById('ar_ordernr').value,
                datum: document.getElementById('ar_datum').value,
                kund: document.getElementById('ar_kund').value,
                projekt: document.getElementById('ar_projekt').value,
                anteckningar: document.getElementById('ar_anteckningar').value,
                status
            };
            
            const result = await saveOrder('ar', jobData);
            if (result) {
                showToast('Arbetsorder sparad');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('jobModal')).hide();
                await loadAndRenderArJobs();
            }
        }
        
        function initArCalendar() {
            const calendarEl = document.getElementById('calendar-ar');
            arCalendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay,listMonth'
                },
                locale: 'sv',
                events: [],
                eventClick: async (info) => {
                    const jobs = await loadOrders('ar');
                    const job = jobs.find(j => j.id === info.event.id);
                    if (job) {
                        currentEditingJobId = job.id;
                        showArJobModal(job);
                    }
                },
                eventDidMount: (info) => {
                    info.el.style.cursor = 'pointer';
                }
            });
            arCalendar.render();
        }
        
        // ============================================================================
        // SÖMNADSORDER (SOM) FUNCTIONS
        // ============================================================================
        
        async function loadAndRenderSomJobs() {
            const jobs = await loadOrders('som');
            renderSomList(jobs);
            updateSomCalendar(jobs);
        }
        
        function renderSomList(jobs) {
            const container = document.getElementById('kommande-som');
            const searchText = document.getElementById('searchSomInput').value.toLowerCase();
            const statusFilter = document.querySelector('#filterSomStatus .status-btn.active')?.dataset.status || 'all';
            
            let filtered = jobs;
            
            if (statusFilter !== 'all') {
                filtered = filtered.filter(j => j.status === statusFilter);
            }
            
            if (searchText) {
                filtered = filtered.filter(j => 
                    (j.ordernr || '').toLowerCase().includes(searchText) ||
                    (j.projekt || '').toLowerCase().includes(searchText)
                );
            }
            
            container.innerHTML = filtered.map(job => `
                <div class="kommande-item" onclick="editSomJob('${job.id}')" style="border-left-color: var(--color-som-primary);">
                    <div class="kommande-item-nr" style="color: var(--color-som-primary);">${job.ordernr}</div>
                    <div class="kommande-item-info">${job.projekt}</div>
                    <div class="kommande-item-info">
                        <span class="status-pill ${job.status}">${job.status}</span>
                    </div>
                </div>
            `).join('');
        }
        
        function updateSomCalendar(jobs) {
            if (!somCalendar) return;
            
            const events = jobs
                .filter(job => job.status !== 'utkast' && job.status !== 'ny' && job.leveransdatum)
                .map(job => ({
                    id: job.id,
                    title: `${job.ordernr} - ${job.kund}`,
                    start: job.leveransdatum,
                    backgroundColor: getStatusColor(job.status, 'som'),
                    borderColor: getStatusColor(job.status, 'som'),
                    textColor: '#fff'
                }));
            
            somCalendar.removeAllEvents();
            somCalendar.addEventSource(events);
        }
        
        async function editSomJob(jobId) {
            const jobs = await loadOrders('som');
            const job = jobs.find(j => j.id === jobId);
            if (!job) return;
            
            currentEditingJobId = jobId;
            currentEditingType = 'som';
            
            showSomJobModal(job);
        }
        
        function showSomJobModal(job = null) {
            const isNew = !job;
            const jobData = job || {
                ordernr: generateOrderNumber('som'),
                status: 'utkast',
                leveransdatum: formatDate(new Date())
            };
            
            document.getElementById('jobModalTitle').textContent = isNew ? 'Ny Sömnadsorder' : `Sömnadsorder ${jobData.ordernr}`;
            
            let formHtml = `
                <div class="form-section">
                    <label class="form-label">Ordernr</label>
                    <input type="text" class="form-control som-field" id="som_ordernr" value="${jobData.ordernr || ''}" readonly style="background: #f0f0f0;">
                </div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-section">
                        <label class="form-label">Leveransdatum</label>
                        <input type="date" class="form-control som-field" id="som_leveransdatum" value="${jobData.leveransdatum || ''}">
                    </div>
                    <div class="form-section">
                        <label class="form-label">Kund</label>
                        <input type="text" class="form-control som-field" id="som_kund" value="${jobData.kund || ''}" placeholder="Kundnamn">
                    </div>
                </div>
                
                <div class="form-section">
                    <label class="form-label">Projekt</label>
                    <input type="text" class="form-control som-field" id="som_projekt" value="${jobData.projekt || ''}" placeholder="Projektnamn">
                </div>
                
                <div class="form-section">
                    <h6 class="form-section-title" style="color: var(--color-som-primary);">Status</h6>
                    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                        <button type="button" class="status-pill ${jobData.status === 'utkast' ? 'active' : ''}" data-som-status="utkast" style="background: ${jobData.status === 'utkast' ? 'var(--status-utkast)' : '#eee'}; color: ${jobData.status === 'utkast' ? 'white' : '#333'};">Utkast</button>
                        <button type="button" class="status-pill ${jobData.status === 'ny' ? 'active' : ''}" data-som-status="ny" style="background: ${jobData.status === 'ny' ? 'var(--status-ny-som)' : '#eee'}; color: white;">NY</button>
                        <button type="button" class="status-pill ${jobData.status === 'sy' ? 'active' : ''}" data-som-status="sy" style="background: ${jobData.status === 'sy' ? 'var(--status-sy)' : '#eee'}; color: white;">Sy</button>
                        <button type="button" class="status-pill ${jobData.status === 'klar' ? 'active' : ''}" data-som-status="klar" style="background: ${jobData.status === 'klar' ? 'var(--status-klar)' : '#eee'}; color: white;">Klar</button>
                    </div>
                </div>
                
                <div class="form-section">
                    <label class="form-label">Anteckningar</label>
                    <textarea class="form-control som-field" id="som_anteckningar" rows="3" placeholder="Noteringar...">${jobData.anteckningar || ''}</textarea>
                </div>
            `;
            
            document.getElementById('jobModalBody').innerHTML = formHtml;
            
            // Setup status pill listeners
            document.querySelectorAll('[data-som-status]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('[data-som-status]').forEach(b => {
                        b.style.background = '#eee';
                        b.style.color = '#333';
                        b.classList.remove('active');
                    });
                    const status = e.target.dataset.somStatus;
                    e.target.style.background = getStatusColor(status, 'som');
                    e.target.style.color = status === 'utkast' ? '#333' : 'white';
                    e.target.classList.add('active');
                });
            });
            
            document.getElementById('saveJobBtn').onclick = () => saveSomJob(jobData);
            
            bootstrap.Modal.getOrCreateInstance(document.getElementById('jobModal')).show();
        }
        
        async function saveSomJob(originalJobData) {
            const activeStatusBtn = document.querySelector('[data-som-status].active');
            const status = activeStatusBtn?.dataset.somStatus || 'utkast';
            
            const jobData = {
                id: currentEditingJobId || ('som_' + Date.now().toString(36) + Math.random().toString(36).slice(2)),
                ordernr: document.getElementById('som_ordernr').value,
                leveransdatum: document.getElementById('som_leveransdatum').value,
                kund: document.getElementById('som_kund').value,
                projekt: document.getElementById('som_projekt').value,
                anteckningar: document.getElementById('som_anteckningar').value,
                status
            };
            
            const result = await saveOrder('som', jobData);
            if (result) {
                showToast('Sömnadsorder sparad');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('jobModal')).hide();
                await loadAndRenderSomJobs();
            }
        }
        
        function initSomCalendar() {
            const calendarEl = document.getElementById('calendar-som');
            somCalendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay,listMonth'
                },
                locale: 'sv',
                events: [],
                eventClick: async (info) => {
                    const jobs = await loadOrders('som');
                    const job = jobs.find(j => j.id === info.event.id);
                    if (job) {
                        currentEditingJobId = job.id;
                        showSomJobModal(job);
                    }
                },
                eventDidMount: (info) => {
                    info.el.style.cursor = 'pointer';
                }
            });
            somCalendar.render();
        }
        
        // ============================================================================
        // BESTÄLLNINGAR (BEST) FUNCTIONS
        // ============================================================================
        
        async function renderBestTable() {
            const jobs = await loadOrders('best');
            const container = document.getElementById('bestTableContainer');
            const searchText = document.getElementById('bestSearchInput').value.toLowerCase();
            
            let filtered = jobs;
            
            if (currentBestFilter !== 'all') {
                filtered = filtered.filter(j => j.status === currentBestFilter);
            }
            
            if (searchText) {
                filtered = filtered.filter(j => 
                    (j.ordernr || '').toLowerCase().includes(searchText)
                );
            }
            
            if (filtered.length === 0) {
                container.innerHTML = '<p style="padding: 2rem; text-align: center; color: #999;">Inga beställningar</p>';
                return;
            }
            
            const html = `
                <table class="best-table">
                    <thead>
                        <tr>
                            <th>Ordernr</th>
                            <th>Leverantör</th>
                            <th>Leveransdatum</th>
                            <th>Status</th>
                            <th>Mottagen</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${filtered.map(b => `
                            <tr onclick="showBestModal('${b.id}')">
                                <td><strong>${b.ordernr}</strong></td>
                                <td>${b.leverantor || '-'}</td>
                                <td>${b.levdatum || '-'}</td>
                                <td><span class="status-pill" style="background: ${getPillColor(b.status)}; color: ${b.status === 'levererad' || b.status === 'oppen' ? 'white' : '#333'};">${b.status}</span></td>
                                <td>${b.mottagen ? '<i class="bi bi-check2 text-success"></i>' : '-'}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;
            
            container.innerHTML = html;
        }
        
        function getPillColor(status) {
            return { oppen: '#F57C00', dellevererad: '#1565C0', levererad: '#2E7D32', avbruten: '#9E9E9E' }[status] || '#9E9E9E';
        }
        
        async function showBestModal(bestId = null) {
            currentEditingBestId = bestId;
            
            let b = null;
            if (bestId) {
                const jobs = await loadOrders('best');
                b = jobs.find(x => x.id === bestId);
            }
            
            const refSel = document.getElementById('bestReferens');
            refSel.innerHTML = '<option value="">-- Välj säljare --</option>' +
                msSalesNames.map(n => `<option value="${n}" ${b && b.referens === n ? 'selected' : ''}>${n}</option>`).join('');

            document.getElementById('bestModalTitle').textContent = b ? `Beställning ${b.ordernr}` : 'Ny beställning';
            document.getElementById('bestOrdernr').value   = b ? b.ordernr   : generateBestOrdernr();
            document.getElementById('bestDatum').value     = b ? b.datum     : formatDate(new Date());
            document.getElementById('bestLevdatum').value  = b ? b.levdatum  : '';
            document.getElementById('bestLeverantor').value= b ? b.leverantor: '';
            document.getElementById('bestProjekt').value   = b ? b.projekt   : '';
            document.getElementById('bestBetalning').value = b ? b.betalning  : '30 dagar netto';
            document.getElementById('bestLevAdress').value = b ? b.levadress  : 'Ribe Gardin AB, Mediavägen 11, 135 48 Tyresö';
            document.getElementById('bestAnteckningar').value = b ? b.anteckningar : '';
            document.getElementById('bestMottagen').checked  = b ? !!b.mottagen : false;

            renderBestArtiklar(b ? b.artiklar : []);

            const currentStatus = b ? b.status : 'oppen';
            document.querySelectorAll('#bestStatusPills .status-pill').forEach(pill => {
                const isActive = pill.dataset.bestStatus === currentStatus;
                pill.style.background = isActive ? getPillColor(pill.dataset.bestStatus) : '#eee';
                pill.style.color = isActive ? 'white' : '#333';
            });

            document.getElementById('bestDeleteBtn').style.display = b ? 'inline-block' : 'none';
            document.getElementById('bestPdfBtn').style.display    = b ? 'inline-block' : 'none';

            bootstrap.Modal.getOrCreateInstance(document.getElementById('bestModal')).show();
        }
        
        function renderBestArtiklar(artiklar) {
            const tbody = document.getElementById('bestArtiklarBody');
            const rows = (artiklar && artiklar.length > 0 ? artiklar : [{ artikelnr: '', beskrivning: '', markning: '', antal: '', enhet: 'm' }]);
            tbody.innerHTML = rows.map((a, i) => `
                <tr>
                    <td><input type="text" value="${a.artikelnr || ''}" placeholder="Artikelnr" data-best-field="artikelnr" data-idx="${i}"></td>
                    <td><input type="text" value="${a.beskrivning || ''}" placeholder="Beskrivning" data-best-field="beskrivning" data-idx="${i}"></td>
                    <td><input type="text" value="${a.markning || ''}" placeholder="Märkning" data-best-field="markning" data-idx="${i}"></td>
                    <td><input type="number" value="${a.antal || ''}" placeholder="0" data-best-field="antal" data-idx="${i}"></td>
                    <td><input type="text" value="${a.enhet || 'm'}" placeholder="enhet" data-best-field="enhet" data-idx="${i}"></td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeBestArtikel(${i})"><i class="bi bi-x"></i></button></td>
                </tr>`).join('');
        }
        
        function removeBestArtikel(idx) {
            const artiklar = getBestArtiklarFromForm();
            artiklar.splice(idx, 1);
            renderBestArtiklar(artiklar);
        }
        
        function getBestArtiklarFromForm() {
            const rows = document.querySelectorAll('#bestArtiklarBody tr');
            return Array.from(rows).map(row => ({
                artikelnr:   row.querySelector('[data-best-field="artikelnr"]')?.value  || '',
                beskrivning: row.querySelector('[data-best-field="beskrivning"]')?.value || '',
                markning:    row.querySelector('[data-best-field="markning"]')?.value    || '',
                antal:       row.querySelector('[data-best-field="antal"]')?.value       || '',
                enhet:       row.querySelector('[data-best-field="enhet"]')?.value       || 'm'
            }));
        }
        
        async function saveBestOrder() {
            const activePill = document.querySelector('#bestStatusPills .status-pill[style*="white"]');
            const status = activePill ? activePill.dataset.bestStatus : 'oppen';

            const b = {
                id:           currentEditingBestId || ('best_' + Date.now().toString(36)),
                ordernr:      document.getElementById('bestOrdernr').value,
                datum:        document.getElementById('bestDatum').value,
                levdatum:     document.getElementById('bestLevdatum').value,
                leverantor:   document.getElementById('bestLeverantor').value,
                referens:     document.getElementById('bestReferens').value,
                projekt:      document.getElementById('bestProjekt').value,
                betalning:    document.getElementById('bestBetalning').value,
                levadress:    document.getElementById('bestLevAdress').value,
                anteckningar: document.getElementById('bestAnteckningar').value,
                mottagen:     document.getElementById('bestMottagen').checked,
                artiklar:     getBestArtiklarFromForm(),
                status
            };

            const result = await saveOrder('best', b);
            if (result) {
                showToast('Beställning sparad');
                await renderBestTable();
                bootstrap.Modal.getOrCreateInstance(document.getElementById('bestModal')).hide();
            }
        }
        
        async function deleteBestOrder() {
            if (!currentEditingBestId) return;
            if (!confirm('Ta bort denna beställning?')) return;
            
            const result = await deleteOrder('best', currentEditingBestId);
            if (result) {
                showToast('Beställning borttagen');
                await renderBestTable();
                bootstrap.Modal.getOrCreateInstance(document.getElementById('bestModal')).hide();
            }
        }
        
        // ============================================================================
        // EVENT LISTENERS SETUP
        // ============================================================================
        
        function setupEventListeners() {
            // Login/Logout
            document.getElementById('loginBtnMsal').addEventListener('click', handleLogin);
            document.getElementById('logoutBtn').addEventListener('click', handleLogout);
            
            // Tab switching
            document.querySelectorAll('.nav-link').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    switchTab(e.currentTarget.dataset.tab);
                });
            });
            
            // Arbetsorder
            document.getElementById('newArJobBtn').addEventListener('click', () => {
                currentEditingJobId = null;
                showArJobModal();
            });
            
            document.getElementById('searchArInput').addEventListener('input', async () => {
                const jobs = await loadOrders('ar');
                renderArList(jobs);
            });
            
            document.getElementById('filterArStatus').addEventListener('click', async (e) => {
                if (e.target.classList.contains('status-btn')) {
                    document.querySelectorAll('#filterArStatus .status-btn').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    const jobs = await loadOrders('ar');
                    renderArList(jobs);
                }
            });
            
            // Sömnadsorder
            document.getElementById('newSomJobBtn').addEventListener('click', () => {
                currentEditingJobId = null;
                showSomJobModal();
            });
            
            document.getElementById('searchSomInput').addEventListener('input', async () => {
                const jobs = await loadOrders('som');
                renderSomList(jobs);
            });
            
            document.getElementById('filterSomStatus').addEventListener('click', async (e) => {
                if (e.target.classList.contains('status-btn')) {
                    document.querySelectorAll('#filterSomStatus .status-btn').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    const jobs = await loadOrders('som');
                    renderSomList(jobs);
                }
            });
            
            // Beställningar
            document.getElementById('newBestBtn').addEventListener('click', () => showBestModal(null));
            
            document.getElementById('bestSearchInput').addEventListener('input', renderBestTable);
            
            document.querySelectorAll('.best-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.best-filter-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentBestFilter = btn.dataset.bestFilter;
                    renderBestTable();
                });
            });
            
            document.getElementById('addBestArtikelBtn').addEventListener('click', () => {
                const artiklar = getBestArtiklarFromForm();
                artiklar.push({ artikelnr: '', beskrivning: '', markning: '', antal: '', enhet: 'm' });
                renderBestArtiklar(artiklar);
            });
            
            document.getElementById('bestStatusPills').addEventListener('click', e => {
                const pill = e.target.closest('.status-pill');
                if (!pill) return;
                document.querySelectorAll('#bestStatusPills .status-pill').forEach(p => {
                    p.style.background = '#eee'; p.style.color = '#333';
                });
                pill.style.background = getPillColor(pill.dataset.bestStatus);
                pill.style.color = 'white';
            });
            
            document.getElementById('bestSaveBtn').addEventListener('click', saveBestOrder);
            document.getElementById('bestDeleteBtn').addEventListener('click', deleteBestOrder);
            
            // Fortnox sync
            document.getElementById('fortnoxSyncBtn').addEventListener('click', syncFortnox);
            
            // Settings
            document.getElementById('settingsBtn').addEventListener('click', () => {
                bootstrap.Modal.getOrCreateInstance(document.getElementById('settingsModal')).show();
            });
            
            document.getElementById('saveSettingsBtn').addEventListener('click', async () => {
                const settings = {
                    companyName: document.getElementById('settingsCompanyName').value
                };
                await apiCall('POST', '/settings', settings);
                showToast('Inställningar sparade');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('settingsModal')).hide();
            });
        }
        
        // ============================================================================
        // INITIALIZE APPLICATION
        // ============================================================================
        
        window.addEventListener('load', initMsal);
    </script>

</body>
</html>
